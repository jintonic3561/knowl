{
  // 本番動作コンテナと同じレシピを使うため、docker/Dockerfile の base ステージを直接ビルドする。
  // 共通ツール (uv, gh, claude, docker-cli) はそちらで導入済 -> features 側では重複させない。
  "name": "knowl",
  "build": {
    "dockerfile": "../docker/Dockerfile",
    "context": "..",
    "target": "base"
  },
  "features": {
    // Node.js（Codex/OpenAI docs helper等で利用）
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    // Docker in Docker（compose で knowl コンテナを起動して疎通確認するため）
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    }
  },
  // Knowl から `docker exec` で叩けるよう固定名で起動する (knowl オーケストレータ自身は container_name: knowl)
  "runArgs": ["--name", "knowl-dev"],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "UV_LINK_MODE": "copy"
  },
  "customizations": {
    "vscode": {
      "extensions": ["charliermarsh.ruff", "ms-python.python", "ms-vscode.live-server"],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python"
      }
    }
  }
}
