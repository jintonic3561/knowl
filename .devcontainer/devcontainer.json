{
  // ローカルWSLにdockerが無いためビルド未検証。Docker Desktop/リモートで利用想定。
  "name": "knowl",
  "image": "mcr.microsoft.com/devcontainers/python:3.13-bookworm",
  "features": {
    // uv（パッケージ管理）。問題時は公式インストーラ(curl -LsSf https://astral.sh/uv/install.sh|sh)に切替可
    "ghcr.io/va-h/devcontainers-features/uv:1": {
      "version": "latest"
    },
    // GitHub CLI（gh）。digestはlockでpin（uvと同様）
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    // Node.js（Codex/OpenAI docs helper等で利用）
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    // Docker in Docker（compose で knowl コンテナを起動して疎通確認するため）
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    }
  },
  // Knowl から `docker exec` で叩けるよう固定名で起動する (knowl オーケストレータ自身は container_name: knowl)
  "runArgs": ["--name", "knowl-dev"],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "UV_LINK_MODE": "copy"
  },
  "customizations": {
    "vscode": {
      "extensions": ["charliermarsh.ruff", "ms-python.python", "ms-vscode.live-server"],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python"
      }
    }
  }
}
